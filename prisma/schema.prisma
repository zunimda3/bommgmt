generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  designer
  purchaser
}

enum PartCategory {
  fabrication
  standard_part
  modifications
}

enum ProjectStatus {
  draft
  active
  completed
  archived
}

enum PurchasingStatus {
  pending
  quoted
  ordered
  received
}

model User {
  id                    String         @id @default(cuid())
  name                  String
  email                 String         @unique
  role                  Role
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  announcements         Announcement[]
  createdProjects       Project[]      @relation("ProjectCreator")
  assignedDesignProjects Project[]     @relation("ProjectDesigner")
  assignedPurchaseProjects Project[]   @relation("ProjectPurchaser")
  sessions              Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Project {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  description  String
  status       ProjectStatus    @default(active)
  designerId   String?
  purchaserId  String?
  createdById  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  designer     User?            @relation("ProjectDesigner", fields: [designerId], references: [id], onDelete: SetNull)
  purchaser    User?            @relation("ProjectPurchaser", fields: [purchaserId], references: [id], onDelete: SetNull)
  createdBy    User             @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  modules      ProjectModule[]
  purchasingItems PurchasingItem[]
}

model ProjectModule {
  id           String    @id @default(cuid())
  projectId    String
  name         String
  displayOrder Int
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bomItems     BomItem[]

  @@unique([projectId, name])
}

model BomItem {
  id              String       @id @default(cuid())
  projectModuleId String
  itemCode        Int
  partNumber      String
  partDescription String
  vendor          String
  partCategory    PartCategory
  quantity        Int
  price           Decimal      @db.Decimal(12, 2)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  projectModule   ProjectModule @relation(fields: [projectModuleId], references: [id], onDelete: Cascade)

  @@unique([projectModuleId, itemCode])
}

model PurchasingItem {
  id               String           @id @default(cuid())
  projectId        String
  aggregateKey     String           @unique
  partNumber       String
  partDescription  String
  vendor           String
  partCategory     PartCategory
  totalQuantity    Int
  status           PurchasingStatus @default(pending)
  supplierSelected String?
  quotedPrice      Decimal?         @db.Decimal(12, 2)
  poNumber         String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
